// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// @version=6
// © acekavi
// =============================================================================
// S&D + HTF Liquidity INDICATOR  —  with Stoch RSI + EMA + VWAP confluence
// =============================================================================
indicator("S&D + HTF Liquidity", "S&D+HTF",
     overlay          = true,
     max_boxes_count  = 100,
     max_lines_count  = 200,
     max_labels_count = 200)

// ─────────────────────────────────────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────────────────────────────────────
color BULL_COLOR  = #089981
color BEAR_COLOR  = #f23645
color LIQ_D_COLOR = #5b9cf6
color LIQ_4_COLOR = #9c5bf6
color EMA_FAST_COLOR = #ffeb3b
color EMA_MID_COLOR  = #ff9800
color EMA_SLOW_COLOR = #e91e63
color VWAP_COLOR     = #00bcd4

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
int   lookbackInput = input.int(14,    "ATR Period",              minval = 1,                group = "Supply & Demand")
float strengthInput = input.float(1.2, "Move Strength (ATR ×)",   minval = 0.1, step = 0.1, group = "Supply & Demand")
int   maxZonesInput = input.int(5,     "Max Zones per Type",      minval = 1,   maxval = 50, group = "Supply & Demand")

int  pivotLookback = input.int(3,    "Pivot Lookback",            minval = 1,                group = "HTF Swings")
bool showDaily     = input.bool(true, "Show Daily Swings",                                   group = "HTF Swings")
bool show4H        = input.bool(true, "Show 4H Swings",                                      group = "HTF Swings")
bool showPDHL      = input.bool(true, "Show Prev Day High/Low",                              group = "HTF Swings")
int  maxLiqLines   = input.int(10,   "Max Tracked Levels per TF", minval = 1,   maxval = 30, group = "HTF Swings")

// Stoch RSI inputs
int   srsiLengthRSI  = input.int(14,  "RSI Length",               minval = 1,                group = "Stoch RSI Confluence")
int   srsiLengthK    = input.int(14,  "Stoch Length",             minval = 1,                group = "Stoch RSI Confluence")
int   srsiSmoothK    = input.int(3,   "K Smoothing",              minval = 1,                group = "Stoch RSI Confluence")
int   srsiSmoothD    = input.int(3,   "D Smoothing",              minval = 1,                group = "Stoch RSI Confluence")
float srsiOB         = input.float(80, "Overbought Level",        minval = 50,  maxval = 100, group = "Stoch RSI Confluence")
float srsiOS         = input.float(20, "Oversold Level",          minval = 0,   maxval = 50,  group = "Stoch RSI Confluence")
bool  showConfluence = input.bool(true, "Show Confluence Signals",                            group = "Stoch RSI Confluence")

// EMA inputs
bool  showEMAs      = input.bool(true, "Show EMAs",                                           group = "EMA & VWAP Filters")
int   emaFastLen    = input.int(9,    "Fast EMA Length",          minval = 1,                 group = "EMA & VWAP Filters")
int   emaMidLen     = input.int(21,   "Mid EMA Length",           minval = 1,                 group = "EMA & VWAP Filters")
int   emaSlowLen    = input.int(50,   "Slow EMA (Bias) Length",   minval = 1,                 group = "EMA & VWAP Filters")
bool  useEMABias    = input.bool(true, "Filter: Require EMA Trend Alignment",                 group = "EMA & VWAP Filters",
     tooltip = "Long requires Fast EMA > Mid EMA. Short requires Fast EMA < Mid EMA.")
bool  useEMASlowBias = input.bool(true, "Filter: Require Slow EMA Bias",                      group = "EMA & VWAP Filters",
     tooltip = "Long requires close > Slow EMA. Short requires close < Slow EMA.")

// VWAP inputs
bool  showVWAP      = input.bool(true, "Show VWAP",                                           group = "EMA & VWAP Filters")
bool  useVWAPBias   = input.bool(true, "Filter: Require VWAP Side Alignment",                 group = "EMA & VWAP Filters",
     tooltip = "Long requires close > VWAP. Short requires close < VWAP. Disable for strict counter-trend reversal trades.")

// ─────────────────────────────────────────────────────────────────────────────
// TYPES
// ─────────────────────────────────────────────────────────────────────────────
type Zone
    box   id
    float top
    float bottom
    bool  isBull
    bool  mitigated

type Liquidity
    line  id
    label lbl
    float level
    bool  isBSL
    bool  swept
    int   pivotTime
    string tfName
    color  tfColor

// ─────────────────────────────────────────────────────────────────────────────
// GLOBAL STATE
// ─────────────────────────────────────────────────────────────────────────────
var demandZones  = array.new<Zone>()
var supplyZones  = array.new<Zone>()
var liqLevels    = array.new<Liquidity>()

var processedDailyTimes = array.new<int>()
var processed4HTimes    = array.new<int>()

var line  dBSLLine  = na
var label dBSLLabel = na
var line  dSSLLine  = na
var label dSSLLabel = na
var line  hBSLLine  = na
var label hBSLLabel = na
var line  hSSLLine  = na
var label hSSLLabel = na

var int shownDailyBSL = na
var int shownDailySSL = na
var int shown4hBSL    = na
var int shown4hSSL    = na

// ─────────────────────────────────────────────────────────────────────────────
// EMA CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────
float emaFast = ta.ema(close, emaFastLen)
float emaMid  = ta.ema(close, emaMidLen)
float emaSlow = ta.ema(close, emaSlowLen)

plot(showEMAs ? emaFast : na, "Fast EMA", color = color.new(EMA_FAST_COLOR, 0), linewidth = 1)
plot(showEMAs ? emaMid  : na, "Mid EMA",  color = color.new(EMA_MID_COLOR,  0), linewidth = 1)
plot(showEMAs ? emaSlow : na, "Slow EMA", color = color.new(EMA_SLOW_COLOR, 0), linewidth = 2)

bool emaBullStack = emaFast > emaMid
bool emaBearStack = emaFast < emaMid
bool emaBullBias  = close   > emaSlow
bool emaBearBias  = close   < emaSlow

// ─────────────────────────────────────────────────────────────────────────────
// VWAP CALCULATION
// ─────────────────────────────────────────────────────────────────────────────
float vwapVal = ta.vwap(hlc3)

plot(showVWAP and timeframe.isintraday ? vwapVal : na, "VWAP",
     color = color.new(VWAP_COLOR, 0), linewidth = 1, style = plot.style_line)

bool aboveVWAP = close > vwapVal
bool belowVWAP = close < vwapVal

// ─────────────────────────────────────────────────────────────────────────────
// STOCHASTIC RSI CALCULATION
// ─────────────────────────────────────────────────────────────────────────────
float rsiVal  = ta.rsi(close, srsiLengthRSI)
float stochK  = ta.sma(ta.stoch(rsiVal, rsiVal, rsiVal, srsiLengthK), srsiSmoothK)
float stochD  = ta.sma(stochK, srsiSmoothD)

// ─────────────────────────────────────────────────────────────────────────────
// PREVIOUS DAY HIGH / LOW
// Lines: 5 bars left → 5 bars right of current bar
// Labels: opaque background, overlap-aware Y offset
// ─────────────────────────────────────────────────────────────────────────────
float pdHigh = request.security(syminfo.tickerid, "1D", high[1],  lookahead = barmerge.lookahead_on)
float pdLow  = request.security(syminfo.tickerid, "1D", low[1],   lookahead = barmerge.lookahead_on)

var line  pdHighLine  = na
var line  pdLowLine   = na
var label pdHighLabel = na
var label pdLowLabel  = na

// ─────────────────────────────────────────────────────────────────────────────
// HELPER: draw a fixed-width level line (5 left, 5 right) + opaque label
// Returns [line, label]
// ─────────────────────────────────────────────────────────────────────────────
draw_fixed_line(float lvl, string txt, color col) =>
    int x1 = bar_index - 100
    int x2 = bar_index + 100
    line  l  = line.new(x1, lvl, x2, lvl,
                 color = color.new(col, 20),
                 style = line.style_dashed, width = 1)
    label lb = label.new(x2, lvl, txt,
                 color     = color.new(col, 20),
                 textcolor = color.white,
                 style     = label.style_label_left,
                 size      = size.small)
    [l, lb]

// ─────────────────────────────────────────────────────────────────────────────
// HELPER: delete a line + label pair
// ─────────────────────────────────────────────────────────────────────────────
del_ll(line l, label lb) =>
    if not na(l)
        l.delete()
    if not na(lb)
        lb.delete()

// ─────────────────────────────────────────────────────────────────────────────
// PDH / PDL drawing — redraw every bar so lines track current position
// ─────────────────────────────────────────────────────────────────────────────
if showPDHL and timeframe.isintraday
    // Delete previous drawings each bar so we redraw at current bar_index
    if not na(pdHighLine)
        pdHighLine.delete()
    if not na(pdLowLine)
        pdLowLine.delete()
    if not na(pdHighLabel)
        pdHighLabel.delete()
    if not na(pdLowLabel)
        pdLowLabel.delete()

    [hl, hlb] = draw_fixed_line(pdHigh, "PDH", LIQ_D_COLOR)
    pdHighLine  := hl
    pdHighLabel := hlb

    [ll, llb] = draw_fixed_line(pdLow,  "PDL", LIQ_D_COLOR)
    pdLowLine  := ll
    pdLowLabel := llb

// ─────────────────────────────────────────────────────────────────────────────
// SUPPLY & DEMAND ZONE CREATION  (ICT Order Block rule)
// ─────────────────────────────────────────────────────────────────────────────
float atr          = ta.atr(lookbackInput)
float body         = math.abs(close - open)
bool  isStrongUp   = close > open and body > atr * strengthInput
bool  isStrongDown = close < open and body > atr * strengthInput
bool  baseIsBearish = open[1] > close[1]
bool  baseIsBullish = open[1] < close[1]

if isStrongUp and baseIsBearish
    box zBox = box.new(bar_index - 1, high[1], bar_index, low[1],
         border_color = color.new(BULL_COLOR, 50),
         bgcolor      = color.new(BULL_COLOR, 85), extend = extend.right)
    array.push(demandZones, Zone.new(zBox, high[1], low[1], true, false))

if isStrongDown and baseIsBullish
    box zBox = box.new(bar_index - 1, high[1], bar_index, low[1],
         border_color = color.new(BEAR_COLOR, 50),
         bgcolor      = color.new(BEAR_COLOR, 85), extend = extend.right)
    array.push(supplyZones, Zone.new(zBox, high[1], low[1], false, false))

// ─────────────────────────────────────────────────────────────────────────────
// HTF PIVOT FETCH
// ─────────────────────────────────────────────────────────────────────────────
[phD, plD, timeD] = request.security(syminfo.tickerid, "1D",
     [ta.pivothigh(high, pivotLookback, pivotLookback)[1],
      ta.pivotlow (low,  pivotLookback, pivotLookback)[1],
      time[pivotLookback]],
     lookahead = barmerge.lookahead_on)

[ph4, pl4, time4] = request.security(syminfo.tickerid, "240",
     [ta.pivothigh(high, pivotLookback, pivotLookback)[1],
      ta.pivotlow (low,  pivotLookback, pivotLookback)[1],
      time[pivotLookback]],
     lookahead = barmerge.lookahead_on)

// ─────────────────────────────────────────────────────────────────────────────
// REGISTER HTF LEVELS
// ─────────────────────────────────────────────────────────────────────────────
register_htf_liq(float pVal, int pTime, bool isBSL, string tfName, color tfColor, array<int> tracker) =>
    if not na(pVal) and not na(pTime)
        if array.indexof(tracker, pTime) == -1
            array.push(tracker, pTime)
            array.push(liqLevels,
                 Liquidity.new(na, na, pVal, isBSL, false, pTime, tfName, tfColor))

if showDaily and timeframe.isintraday
    register_htf_liq(phD, timeD, true,  "1D", LIQ_D_COLOR, processedDailyTimes)
    register_htf_liq(plD, timeD, false, "1D", LIQ_D_COLOR, processedDailyTimes)

if show4H and timeframe.in_seconds() < timeframe.in_seconds("240")
    register_htf_liq(ph4, time4, true,  "4H", LIQ_4_COLOR, processed4HTimes)
    register_htf_liq(pl4, time4, false, "4H", LIQ_4_COLOR, processed4HTimes)

// ─────────────────────────────────────────────────────────────────────────────
// ZONE MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────
manageZones(array<Zone> zoneArray, bool isBull) =>
    if array.size(zoneArray) > 0
        for i = array.size(zoneArray) - 1 to 0
            Zone z = array.get(zoneArray, i)
            if not z.mitigated
                bool mitigated = isBull ? close < z.bottom : close > z.top
                if mitigated
                    z.mitigated := true
                    z.id.delete()
                    array.remove(zoneArray, i)
        while array.size(zoneArray) > maxZonesInput
            Zone oldZone = array.remove(zoneArray, 0)
            oldZone.id.delete()

manageZones(demandZones, true)
manageZones(supplyZones, false)

// ─────────────────────────────────────────────────────────────────────────────
// ZONE PRESENCE HELPERS
// ─────────────────────────────────────────────────────────────────────────────
inDemandZone() =>
    bool result = false
    int dSize = array.size(demandZones)
    if dSize > 0
        for i = 0 to dSize - 1
            Zone z = array.get(demandZones, i)
            if not z.mitigated and close >= z.bottom and close <= z.top
                result := true
    result

inSupplyZone() =>
    bool result = false
    int sSize = array.size(supplyZones)
    if sSize > 0
        for i = 0 to sSize - 1
            Zone z = array.get(supplyZones, i)
            if not z.mitigated and close >= z.bottom and close <= z.top
                result := true
    result

// ─────────────────────────────────────────────────────────────────────────────
// CLOSEST LEVEL SELECTION + VISIBLE LINE MANAGEMENT
//
// Lines:  fixed-width, bar_index-5 → bar_index+5, redrawn each bar
// Labels: opaque colored background, overlap-aware positioning
//
// Overlap logic: if a BSL/SSL level is within (atr * 0.15) of a PDH/PDL,
// the label is nudged one position (label_lower_left vs label_upper_left)
// so both are readable without stacking on top of each other.
// ─────────────────────────────────────────────────────────────────────────────

// draw_ll: fixed-width line + opaque label for BSL/SSL levels
// labelBelow = true  → label sits below the line (label_upper_left)
// labelBelow = false → label sits above the line (label_lower_left)  [default]
draw_ll(float lvl, string txt, color col, bool labelBelow = false) =>
    int x1 = bar_index - 150
    int x2 = bar_index + 150
    line  l  = line.new(x1, lvl, x2, lvl,
                 color = color.new(col, 30),
                 style = line.style_dashed, width = 1)
    label lb = label.new(x2, lvl, txt,
                 color     = color.new(col, 20),
                 textcolor = color.white,
                 style     = labelBelow ? label.style_label_upper_left : label.style_label_lower_left,
                 size      = size.small)
    [l, lb]

// Proximity threshold for overlap detection (fraction of ATR)
float overlapThresh = atr * 0.15

// Helper: is a BSL/SSL level close to PDH or PDL?
nearPDHL(float lvl) =>
    (not na(pdHigh) and math.abs(lvl - pdHigh) < overlapThresh) or (not na(pdLow)  and math.abs(lvl - pdLow)  < overlapThresh)

if array.size(liqLevels) > 0
    float dBSLBest = na
    int dBSLTime = na
    float dSSLBest = na
    int dSSLTime = na
    float hBSLBest = na
    int hBSLTime = na
    float hSSLBest = na
    int hSSLTime = na

    for i = 0 to array.size(liqLevels) - 1
        Liquidity lq = array.get(liqLevels, i)
        if lq.swept
            continue
        bool isDaily = lq.tfName == "1D"
        bool is4H    = lq.tfName == "4H"
        if lq.isBSL and lq.level > close
            if isDaily and (na(dBSLBest) or lq.level < dBSLBest)
                dBSLBest := lq.level
                dBSLTime := lq.pivotTime
            else if is4H and (na(hBSLBest) or lq.level < hBSLBest)
                hBSLBest := lq.level
                hBSLTime := lq.pivotTime
        if not lq.isBSL and lq.level < close
            if isDaily and (na(dSSLBest) or lq.level > dSSLBest)
                dSSLBest := lq.level
                dSSLTime := lq.pivotTime
            else if is4H and (na(hSSLBest) or lq.level > hSSLBest)
                hSSLBest := lq.level
                hSSLTime := lq.pivotTime

    // ── 1D BSL ──
    if not na(dBSLBest)
        if na(shownDailyBSL) or shownDailyBSL != dBSLTime
            del_ll(dBSLLine, dBSLLabel)
            [nl, nlb] = draw_ll(dBSLBest, "1D BSL", LIQ_D_COLOR, nearPDHL(dBSLBest))
            dBSLLine := nl
            dBSLLabel := nlb
            shownDailyBSL := dBSLTime
        else
            // Redraw at current bar_index so line tracks current bar
            del_ll(dBSLLine, dBSLLabel)
            [nl, nlb] = draw_ll(dBSLBest, "1D BSL", LIQ_D_COLOR, nearPDHL(dBSLBest))
            dBSLLine  := nl
            dBSLLabel := nlb
    else
        del_ll(dBSLLine, dBSLLabel)
        dBSLLine := na
        dBSLLabel := na
        shownDailyBSL := na

    // ── 1D SSL ──
    if not na(dSSLBest)
        if na(shownDailySSL) or shownDailySSL != dSSLTime
            del_ll(dSSLLine, dSSLLabel)
            [nl, nlb] = draw_ll(dSSLBest, "1D SSL", LIQ_D_COLOR, nearPDHL(dSSLBest))
            dSSLLine := nl
            dSSLLabel := nlb
            shownDailySSL := dSSLTime
        else
            del_ll(dSSLLine, dSSLLabel)
            [nl, nlb] = draw_ll(dSSLBest, "1D SSL", LIQ_D_COLOR, nearPDHL(dSSLBest))
            dSSLLine  := nl
            dSSLLabel := nlb
    else
        del_ll(dSSLLine, dSSLLabel)
        dSSLLine := na
        dSSLLabel := na
        shownDailySSL := na

    // ── 4H BSL ──
    if not na(hBSLBest)
        if na(shown4hBSL) or shown4hBSL != hBSLTime
            del_ll(hBSLLine, hBSLLabel)
            [nl, nlb] = draw_ll(hBSLBest, "4H BSL", LIQ_4_COLOR, nearPDHL(hBSLBest))
            hBSLLine := nl
            hBSLLabel := nlb
            shown4hBSL := hBSLTime
        else
            del_ll(hBSLLine, hBSLLabel)
            [nl, nlb] = draw_ll(hBSLBest, "4H BSL", LIQ_4_COLOR, nearPDHL(hBSLBest))
            hBSLLine  := nl
            hBSLLabel := nlb
    else
        del_ll(hBSLLine, hBSLLabel)
        hBSLLine := na
        hBSLLabel := na
        shown4hBSL := na

    // ── 4H SSL ──
    if not na(hSSLBest)
        if na(shown4hSSL) or shown4hSSL != hSSLTime
            del_ll(hSSLLine, hSSLLabel)
            [nl, nlb] = draw_ll(hSSLBest, "4H SSL", LIQ_4_COLOR, nearPDHL(hSSLBest))
            hSSLLine := nl
            hSSLLabel := nlb
            shown4hSSL := hSSLTime
        else
            del_ll(hSSLLine, hSSLLabel)
            [nl, nlb] = draw_ll(hSSLBest, "4H SSL", LIQ_4_COLOR, nearPDHL(hSSLBest))
            hSSLLine  := nl
            hSSLLabel := nlb
    else
        del_ll(hSSLLine, hSSLLabel)
        hSSLLine := na
        hSSLLabel := na
        shown4hSSL := na

// ─────────────────────────────────────────────────────────────────────────────
// LIQUIDITY SWEEP DETECTION
// ─────────────────────────────────────────────────────────────────────────────
int liqSize = array.size(liqLevels)
if liqSize > 0
    for i = liqSize - 1 to 0
        if i >= array.size(liqLevels)
            continue
        Liquidity lq = array.get(liqLevels, i)
        if not lq.swept
            bool bslSwept = lq.isBSL     and high > lq.level and close < lq.level
            bool sslSwept = not lq.isBSL and low  < lq.level and close > lq.level
            if sslSwept or bslSwept
                lq.swept := true
                if not na(lq.id)
                    lq.id.delete()
                if not na(lq.lbl)
                    lq.lbl.delete()
                array.remove(liqLevels, i)

while array.size(liqLevels) > maxLiqLines * 2
    Liquidity oldLiq = array.remove(liqLevels, 0)
    if not na(oldLiq.id)
        oldLiq.id.delete()
    if not na(oldLiq.lbl)
        oldLiq.lbl.delete()

while array.size(processedDailyTimes) > 200
    array.remove(processedDailyTimes, 0)
while array.size(processed4HTimes) > 200
    array.remove(processed4HTimes, 0)

// ─────────────────────────────────────────────────────────────────────────────
// CONFLUENCE SIGNALS  (Stoch RSI + S&D zone + EMA + VWAP)
// ─────────────────────────────────────────────────────────────────────────────
bool kCrossAboveD = ta.crossover(stochK,  stochD)
bool kCrossBelowD = ta.crossunder(stochK, stochD)

bool baseLong  = kCrossAboveD and stochK <= srsiOS and stochD <= srsiOS and inDemandZone()
bool baseShort = kCrossBelowD and stochK >= srsiOB and stochD >= srsiOB and inSupplyZone()

bool emaLongOK    = not useEMABias     or emaBullStack
bool emaShortOK   = not useEMABias     or emaBearStack
bool slowLongOK   = not useEMASlowBias or emaBullBias
bool slowShortOK  = not useEMASlowBias or emaBearBias
bool vwapLongOK   = not useVWAPBias    or aboveVWAP
bool vwapShortOK  = not useVWAPBias    or belowVWAP

bool longSetup  = baseLong  and emaLongOK  and slowLongOK  and vwapLongOK
bool shortSetup = baseShort and emaShortOK and slowShortOK and vwapShortOK

buildConfluenceText(bool isLong) =>
    string txt = isLong ? "⬆ Long" : "⬇ Short"
    txt := txt + "\nStochRSI " + (isLong ? "OS" : "OB")
    txt := txt + "\n+ " + (isLong ? "Demand" : "Supply") + " Zone"
    if useEMABias
        txt := txt + "\n+ EMA " + str.tostring(emaFastLen) + "/" + str.tostring(emaMidLen)
    if useEMASlowBias
        txt := txt + "\n+ " + str.tostring(emaSlowLen) + " EMA bias"
    if useVWAPBias
        txt := txt + "\n+ VWAP"
    txt

if showConfluence and barstate.isconfirmed
    if longSetup
        label.new(bar_index, low,
             buildConfluenceText(true),
             color     = color.new(BULL_COLOR, 15),
             textcolor = color.white,
             style     = label.style_label_up,
             size      = size.small,
             yloc      = yloc.belowbar)

    if shortSetup
        label.new(bar_index, high,
             buildConfluenceText(false),
             color     = color.new(BEAR_COLOR, 15),
             textcolor = color.white,
             style     = label.style_label_down,
             size      = size.small,
             yloc      = yloc.abovebar)

alertcondition(longSetup,  "Long Confluence",  "S&D+HTF: Long confluence (StochRSI + Demand + filters)")
alertcondition(shortSetup, "Short Confluence", "S&D+HTF: Short confluence (StochRSI + Supply + filters)")

// ─────────────────────────────────────────────────────────────────────────────
// DAILY BIAS LABEL  (ICT methodology)
// ─────────────────────────────────────────────────────────────────────────────
float yd_close = request.security(syminfo.tickerid, "1D", close[1], lookahead = barmerge.lookahead_on)
float yd_high  = request.security(syminfo.tickerid, "1D", high[1],  lookahead = barmerge.lookahead_on)
float yd_low   = request.security(syminfo.tickerid, "1D", low[1],   lookahead = barmerge.lookahead_on)
float pd2_high = request.security(syminfo.tickerid, "1D", high[2],  lookahead = barmerge.lookahead_on)
float pd2_low  = request.security(syminfo.tickerid, "1D", low[2],   lookahead = barmerge.lookahead_on)

bool bullBias    = yd_close > pd2_high
bool bearBias    = yd_close < pd2_low
bool bullLiqGrab = yd_low  < pd2_low  and yd_close > pd2_low  and not bullBias and not bearBias
bool bearLiqGrab = yd_high > pd2_high and yd_close < pd2_high and not bullBias and not bearBias

string biasText = ""
color  biasBg   = color.new(color.gray, 80)

if bullBias
    biasText := "▲ Bullish"
    biasBg   := color.new(#089981, 80)
else if bearBias
    biasText := "▼ Bearish"
    biasBg   := color.new(#f23645, 80)
else if bullLiqGrab
    biasText := "▲ Bullish  [SSL Grab]"
    biasBg   := color.new(#089981, 88)
else if bearLiqGrab
    biasText := "▼ Bearish  [BSL Grab]"
    biasBg   := color.new(#f23645, 88)
else
    biasText := "◆ Neutral / Ranging"
    biasBg   := color.new(color.gray, 80)

var label biasLabel = na
if barstate.islast
    if not na(biasLabel)
        biasLabel.delete()
    biasLabel := label.new(bar_index, high,
         "  Daily Bias\n  " + biasText + "  ",
         xloc      = xloc.bar_index,
         yloc      = yloc.abovebar,
         color     = biasBg,
         textcolor = color.white,
         style     = label.style_label_lower_left,
         size      = size.normal,
         tooltip   = "ICT Bias: yesterday close vs day-before-yesterday range.\n" +
                     "Prior High: "  + str.tostring(pd2_high, format.mintick) +
                     "  Prior Low: " + str.tostring(pd2_low,  format.mintick) + "\n" +
                     "Yd Close: "    + str.tostring(yd_close, format.mintick))
